---
import type { SiteConfig } from "../types/content";

type Props = {
  site: SiteConfig;
};

const { site } = Astro.props;
const base = import.meta.env.BASE_URL;

function withBase(href: string) {
  if (!href.startsWith("/") || href.startsWith("//")) {
    return href;
  }

  const normalizedBase = base.endsWith("/") ? base.slice(0, -1) : base;
  return `${normalizedBase}${href}`;
}
---

<section class="hero reveal" id="top" transition:name="hero">
  <p class="eyebrow">{site.role}</p>
  <h1>{site.name}</h1>
  <p class="lede">{site.tagline}</p>

  <div class="hero-meta">
    <span>{site.location}</span>
    {site.availability && <span>{site.availability}</span>}
  </div>

  <div class="cta-row">
    {
      site.ctaLinks.map((link) => (
        <a
          href={withBase(link.href)}
          class={`btn ${link.variant === "secondary" ? "secondary" : "primary"}`}
        >
          {link.label}
        </a>
      ))
    }
  </div>
</section>
