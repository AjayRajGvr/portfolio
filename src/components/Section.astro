---
type Props = {
  id: string;
  title: string;
  subtitle?: string;
};

const { id, title, subtitle } = Astro.props;
---

<section id={id} class="section reveal" transition:name={id}>
  <div class="section-heading">
    <h2>{title}</h2>
    {subtitle && <p class="subtitle">{subtitle}</p>}
  </div>
  <slot />
</section>
